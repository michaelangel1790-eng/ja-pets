{
  "name": "jacuzzi-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "node scripts/install-git-hooks.cjs",
    "git:hooks": "node scripts/install-git-hooks.cjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "deploy:vercel": "npx --yes vercel --prod",
    "lint": "tsc --noEmit --ignoreDeprecations 6.0",
    "test:a11y": "playwright test tests/a11y.spec.ts",
    "gallery:sync": "node scripts/gallery-sync.mjs",
    "optimize:gallery-images": "node scripts/optimize-gallery-images.mjs",
    "refine:logo": "node scripts/apply-user-logo.mjs",
    "seo:assets": "node scripts/generate-seo-assets.mjs",
    "lighthouse:home": "npx --yes lighthouse http://127.0.0.1:3005 --only-categories=performance,accessibility,best-practices,seo --preset=desktop --quiet --chrome-flags=\"--headless=new\" --output=html --output-path=./lighthouse-home.html"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.51.0",
    "@vercel/blob": "^2.3.3",
    "browser-image-compression": "^2.0.2",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "playwright": "^1.59.1",
    "postcss": "^8.5.12",
    "tailwindcss": "latest",
    "typescript": "latest"
  }
}
