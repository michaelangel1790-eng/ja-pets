# כתובת האתר בעולם (חובה לפריסה — SEO, sitemap, OG)
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Google Apps Script (אופציונלי)
GOOGLE_APPS_SCRIPT_URL=
GOOGLE_REVIEWS_SCRIPT_URL=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_GID=0

# Admin — רק בשרת, לא לקומיט
ADMIN_CODE=
ADMIN_SESSION_SECRET=

# --- גלריה בפרודקשן (Vercel) ---
# תמונות סטטיות: שמים קבצים ב-repo תחת public/gallery/ ומריצים deploy.
# העלאה מהאתר (מנהל): דורש Blob Storage — בלי Token העלאה/סידור/מחיקה לא נשמרות בין הפעלות.
#
# הגדרה ב-Vercel Dashboard:
# 1. פרויקט → Storage → Create → Blob → חיבור לפרויקט
# 2. העתק את משתנה הסביבה BLOB_READ_WRITE_TOKEN (או הוסף מהחיבור האוטומטי)
# 3. Deploy מחדש
#
BLOB_READ_WRITE_TOKEN=

# Sentry — מעקב שגיאות (אופציונלי). יוצר פרויקט ב־sentry.io והדבק DSN
NEXT_PUBLIC_SENTRY_DSN=
# אופציונלי אם שונה מהציבורי
SENTRY_DSN=

# Plausible — סטטיסטיקה פרטית (אופציונלי). אחרי הרשמה ב־plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
