# כתובת האתר בעולם (חובה לפריסה — SEO, sitemap, OG)
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Google Apps Script (אופציונלי)
GOOGLE_APPS_SCRIPT_URL=
GOOGLE_REVIEWS_SCRIPT_URL=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_GID=0

# Admin — רק בשרת, לא לקומיט
ADMIN_CODE=
ADMIN_SESSION_SECRET=

# Sentry — מעקב שגיאות (אופציונלי). יוצר פרויקט ב־sentry.io והדבק DSN
NEXT_PUBLIC_SENTRY_DSN=
# אופציונלי אם שונה מהציבורי
SENTRY_DSN=

# Plausible — סטטיסטיקה פרטית (אופציונלי). אחרי הרשמה ב־plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
